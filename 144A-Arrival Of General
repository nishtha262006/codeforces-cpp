#include <iostream>
#include <vector>
using namespace std;
 
int main() {
    int n;
    cin >> n;
 
    vector<int> a(n);
 
    int maxHeight = -1;
    int minHeight = 101;
    int maxPos = 0;
    int minPos = 0;
 
    for (int i = 0; i < n; i++) {
        cin >> a[i];
 
        if (a[i] > maxHeight) {
            maxHeight = a[i];
            maxPos = i;
        }
 
        if (a[i] <= minHeight) {
            minHeight = a[i];
            minPos = i;
        }
    }
 
    int swaps = maxPos + (n - 1 - minPos);
 
    if (maxPos > minPos)
        swaps--;
 
    cout << swaps;
 
    return 0;
}
