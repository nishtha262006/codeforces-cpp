#include <iostream>
using namespace std;

int main() {
    int n;
    cin >> n;

    int score;
    cin >> score;

    int maxScore = score;
    int minScore = score;
    int count = 0;

    for (int i = 1; i < n; i++) {
        cin >> score;

        if (score > maxScore) {
            maxScore = score;
            count++;
        }
        else if (score < minScore) {
            minScore = score;
            count++;
        }
    }

    cout << count;

    return 0;
}
